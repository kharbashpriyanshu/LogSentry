# LogSentry Environment Variables (Example)
# Rename this file to .env and replace the values with your actual API keys

# AbuseIPDB API Key (for Threat Intelligence)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Google Gemini API Key (for the AI SOC Analyst)
GEMINI_API_KEY=your_gemini_api_key_here

# VirusTotal API Key (Optional / For Future Expansion)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
