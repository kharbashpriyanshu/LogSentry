# ============================================================
# LogSentry SIEM — Environment Configuration Example
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# Core
ENVIRONMENT=development
PROJECT_NAME="LogSentry SIEM"
API_V1_STR="/api/v1"
VERSION=1.0.0

# Security
# Comma-separated list of allowed CORS origins (no wildcards in production)
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
# Maximum API request body size in bytes (default: 1 MB)
MAX_REQUEST_SIZE_BYTES=1048576
# Maximum file upload size in bytes (default: 10 MB)
MAX_UPLOAD_SIZE_BYTES=10485760

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=logsentry_db
POSTGRES_PORT=5432
# Override this in production with a managed DB connection string:
# DATABASE_URI=postgresql+asyncpg://user:password@host:5432/logsentry_db

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/logsentry.log

# Detection Engine
DETECTION_BRUTE_FORCE_THRESHOLD=5
DETECTION_BRUTE_FORCE_WINDOW_SECONDS=60
DETECTION_DEFAULT_CONFIDENCE=0.8

# AI Provider — choose one: openai | gemini | ollama
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_URL=http://localhost:11434
AI_MODEL_NAME=gpt-4-turbo
AI_REQUEST_TIMEOUT=30
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=1500

# Threat Intelligence
ABUSEIPDB_API_KEY=
OTX_API_KEY=
ENRICHMENT_CACHE_TTL=3600
ENABLE_ABUSEIPDB=true
ENABLE_OTX=true
ENABLE_MITRE=true
ENRICHMENT_REQUEST_TIMEOUT=10
